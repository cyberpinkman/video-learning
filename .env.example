# Copy to .env.local and fill real values.

# DashScope / Qwen VLM
VIDEO_LEARNING_VISION_PROVIDER=dashscope
DASHSCOPE_API_KEY=sk-xxx
VIDEO_LEARNING_VISION_MODEL=qwen3.6-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VIDEO_LEARNING_CLOUD_FRAME_LIMIT=12
VIDEO_LEARNING_CLOUD_BATCH_SIZE=8
VIDEO_LEARNING_CLOUD_REQUEST_TIMEOUT_MS=120000

# Text-only content analysis. If unset, the system prefers GLM/MiniMax keys when
# present, then reuses the vision provider/model, and falls back to local
# low-confidence analysis when no API key is configured.
# VIDEO_LEARNING_TEXT_PROVIDER=openai
# VIDEO_LEARNING_TEXT_MODEL=gpt-4.1-mini
#
# GLM primary + MiniMax fallback; this path does not call OpenAI.
# VIDEO_LEARNING_TEXT_PROVIDER=glm
# VIDEO_LEARNING_TEXT_FALLBACK_PROVIDER=minimax
# GLM_API_KEY=your-glm-or-zai-key
# GLM_BASE_URL=https://api.z.ai/api/paas/v4
# VIDEO_LEARNING_GLM_MODEL=glm-5.1
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# VIDEO_LEARNING_MINIMAX_MODEL=MiniMax-M2.7-highspeed
#
# For China MiniMax token-plan endpoints, use:
# MINIMAX_CN_API_KEY=your-minimax-cn-key
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
#
# Keep report commands from dumping huge transcript/report text to stdout.
# VIDEO_LEARNING_CLI_MAX_STDOUT_BYTES=12000
# VIDEO_LEARNING_CLI_ALLOW_LARGE_STDOUT=0

# Optional Douyin account discovery fallback. This only enumerates account works;
# it must not download videos or run analysis.
# VIDEO_LEARNING_DOUYIN_ACCOUNT_DISCOVER_CMD=/absolute/path/to/douyin_account_wrapper
# VIDEO_LEARNING_ACCOUNT_DISCOVER_TIMEOUT_MS=120000
# VIDEO_LEARNING_ACCOUNT_DISCOVER_INLINE_LIMIT=5
#
# Douyin account discovery needs a logged-in browser profile for full works
# pagination. Default headless mode will fail with authRequired when no
# sid_guard/sessionid cookie is present. Set headless=0 once to scan-login and
# keep the login state in the profile directory.
# VIDEO_LEARNING_DOUYIN_BROWSER_PROFILE_DIR=$HOME/.video-learning/browser-profiles/douyin
# VIDEO_LEARNING_DOUYIN_ACCOUNT_DISCOVER_HEADLESS=1
# VIDEO_LEARNING_DOUYIN_LOGIN_WAIT_MS=180000

# Browser login state used by playwright-media-sniffer.
# Keep real browser profiles, cookies, tokens, and proxy settings local.
VIDEO_LEARNING_BROWSER_PROFILE_DIR=$HOME/.video-learning/browser-profiles/default

# Local STT
VIDEO_LEARNING_STT_ENGINE=faster-whisper
VIDEO_LEARNING_STT_MODEL=small
VIDEO_LEARNING_STT_DEVICE=cpu
VIDEO_LEARNING_STT_COMPUTE_TYPE=int8
VIDEO_LEARNING_STT_LANGUAGE=zh

# Optional dedicated platform wrappers.
# VIDEO_LEARNING_WX_CHANNELS_CMD=/absolute/path/to/wx_channels_wrapper
# VIDEO_LEARNING_RES_DOWNLOADER_CMD=/absolute/path/to/res_downloader_wrapper
